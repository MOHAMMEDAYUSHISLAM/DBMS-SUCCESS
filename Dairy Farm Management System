CREATE TABLE Admin ( admin_id INT PRIMARY KEY AUTO_INCREMENT, name VARCHAR(100), email VARCHAR(100) UNIQUE, password VARCHAR(255), role VARCHAR(50) ); CREATE TABLE Farm ( farm_id INT PRIMARY KEY AUTO_INCREMENT, admin_id INT, farm_name VARCHAR(100), location VARCHAR(150), total_cows INT, FOREIGN KEY (admin_id) REFERENCES Admin(admin_id) ); CREATE TABLE Cow ( cow_id INT PRIMARY KEY AUTO_INCREMENT, farm_id INT, breed VARCHAR(50), age INT, health_status VARCHAR(50), milk_production FLOAT, FOREIGN KEY (farm_id) REFERENCES Farm(farm_id) ); CREATE TABLE Milk_Production ( production_id INT PRIMARY KEY AUTO_INCREMENT, cow_id INT, date DATE, quantity FLOAT, FOREIGN KEY (cow_id) REFERENCES Cow(cow_id) ); CREATE TABLE Expenses ( expense_id INT PRIMARY KEY AUTO_INCREMENT, farm_id INT, type VARCHAR(50), amount FLOAT, date DATE, FOREIGN KEY (farm_id) REFERENCES Farm(farm_id) ); CREATE TABLE Sales ( sales_id INT PRIMARY KEY AUTO_INCREMENT, farm_id INT, date DATE, quantity FLOAT, price FLOAT, FOREIGN KEY (farm_id) REFERENCES Farm(farm_id) ); CREATE TABLE Profit ( profit_id INT PRIMARY KEY AUTO_INCREMENT, farm_id INT, total_income FLOAT, total_expense FLOAT, net_profit FLOAT, time_period VARCHAR(20), FOREIGN KEY (farm_id) REFERENCES Farm(farm_id) ); CREATE TABLE Reports ( report_id INT PRIMARY KEY AUTO_INCREMENT, admin_id INT, report_type VARCHAR(50), generated_date DATE, FOREIGN KEY (admin_id) REFERENCES Admin(admin_id) );
