  // SQL Formatter Settings
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  
  // SQL Syntax Highlighting
  "sql-formatter.uppercase": false,
  "sql-formatter.linesBetweenQueries": 2,
  
  // Database Extension Settings (if using)
  "database-client.autoLimit": 100,
  "database-client.autoFocus": false,
  "database-client.showSchema": true,
  
  // General Editor
  "editor.wordWrap": "on",
  "editor.renderWhitespace": "all",
  "files.encoding": "utf8",
  "files.eol": "\n"
}
